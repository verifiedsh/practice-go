def palindromeFunc(string):
    value = string
    invert = value[::-1]
    if value == invert:
        print("It's a palindrome")
    else:
        print("Not a palindrome")

example_1 = "racecar"

print(palindromeFunc(example_1))

example_2 = "hello"

print(palindromeFunc(example_2))

example_3 = "A man a plan a canal panama"

print(palindromeFunc(example_3))

